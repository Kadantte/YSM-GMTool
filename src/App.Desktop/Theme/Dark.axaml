<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Canonical dark palette (from WinForms ApplyReadabilityPalette). -->
    <Color x:Key="WindowBackgroundColor">#181B21</Color>
    <Color x:Key="SidebarBackgroundColor">#1E222A</Color>
    <Color x:Key="PanelBackgroundColor">#222730</Color>
    <Color x:Key="PanelAltBackgroundColor">#242932</Color>
    <Color x:Key="GridBackgroundColor">#1E2229</Color>
    <Color x:Key="ForegroundColor">#EBEEF5</Color>
    <Color x:Key="MutedForegroundColor">#BCC4D0</Color>
    <Color x:Key="BorderColor">#444E5F</Color>
    <Color x:Key="HeaderBackgroundColor">#303743</Color>
    <Color x:Key="AccentColor">#4876C4</Color>
    <Color x:Key="SelectionForegroundColor">#FFFFFF</Color>
    <Color x:Key="IconColorColor">#DCDCDC</Color>

    <SolidColorBrush x:Key="WindowBackground" Color="{StaticResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="SidebarBackground" Color="{StaticResource SidebarBackgroundColor}" />
    <SolidColorBrush x:Key="PanelBackground" Color="{StaticResource PanelBackgroundColor}" />
    <SolidColorBrush x:Key="PanelAltBackground" Color="{StaticResource PanelAltBackgroundColor}" />
    <SolidColorBrush x:Key="GridBackground" Color="{StaticResource GridBackgroundColor}" />
    <SolidColorBrush x:Key="RowBackground" Color="{StaticResource GridBackgroundColor}" />
    <SolidColorBrush x:Key="GridLine" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="Foreground" Color="{StaticResource ForegroundColor}" />
    <SolidColorBrush x:Key="MutedForeground" Color="{StaticResource MutedForegroundColor}" />
    <SolidColorBrush x:Key="Border" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="HeaderBackground" Color="{StaticResource HeaderBackgroundColor}" />
    <SolidColorBrush x:Key="Accent" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="SelectionBackground" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="SelectionForeground" Color="{StaticResource SelectionForegroundColor}" />
    <SolidColorBrush x:Key="IconColor" Color="{StaticResource IconColorColor}" />
</ResourceDictionary>
