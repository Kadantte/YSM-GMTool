<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:shell="clr-namespace:App.Desktop.Shell"
             x:Class="App.Desktop.Shell.SidebarView"
             x:DataType="shell:SidebarViewModel"
             Background="{DynamicResource SidebarBackground}">
    <Grid Margin="8" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*">
        <!-- Settings / About icon buttons -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
            <Button Name="SettingsButton" ToolTip.Tip="Settings" Padding="6"
                    Command="{Binding $parent[Window].((shell:ShellViewModel)DataContext).OpenSettings}">
                <i:Icon Value="fa-solid fa-gear" />
            </Button>
            <Button Name="AboutButton" ToolTip.Tip="About" Padding="6"
                    Command="{Binding $parent[Window].((shell:ShellViewModel)DataContext).OpenAbout}">
                <i:Icon Value="fa-solid fa-circle-info" />
            </Button>
        </StackPanel>

        <!-- Logo -->
        <Image Grid.Row="1" Source="/Assets/Heaven_logo1.png" Height="90"
               Stretch="Uniform" Margin="0,4,0,12" HorizontalAlignment="Center" />

        <!-- Target player -->
        <TextBlock Grid.Row="2" Text="Player" Foreground="{DynamicResource MutedForeground}" Margin="0,0,0,2" />
        <ComboBox Grid.Row="3" HorizontalAlignment="Stretch" Margin="0,0,0,8"
                  ItemsSource="{Binding Players}"
                  SelectedItem="{Binding SelectedPlayer}"
                  PlaceholderText="self" />

        <!-- Add / remove player -->
        <Grid Grid.Row="4" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,0,0,8">
            <TextBlock Grid.Column="0" Text="New:" VerticalAlignment="Center" Margin="0,0,6,0"
                       Foreground="{DynamicResource MutedForeground}" />
            <TextBox Grid.Column="1" Text="{Binding NewPlayerName}" Watermark="player name" />
            <Button Grid.Column="2" Content="+" Width="34" Margin="4,0,0,0"
                    Command="{Binding AddPlayer}" ToolTip.Tip="Add player" />
            <Button Grid.Column="3" Content="-" Width="34" Margin="4,0,0,0"
                    Command="{Binding RemovePlayer}" ToolTip.Tip="Remove selected player" />
        </Grid>

        <!-- Append toggle -->
        <CheckBox Grid.Row="5" Margin="0,0,0,10"
                  IsChecked="{Binding AppendRun}"
                  Content="Append /run to commands" />

        <!-- Command history header -->
        <TextBlock Grid.Row="6" Text="Command history" FontWeight="SemiBold" Margin="0,0,0,4" />

        <!-- Command history list + actions -->
        <Grid Grid.Row="7" RowDefinitions="*,Auto">
            <Border Grid.Row="0" BorderBrush="{DynamicResource Border}" BorderThickness="1">
                <ListBox ItemsSource="{Binding History}"
                         SelectedItem="{Binding SelectedCommand}"
                         Background="{DynamicResource PanelBackground}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <TextBlock Text="{Binding}" TextWrapping="NoWrap"
                                       FontFamily="Consolas, Menlo, monospace" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
            <WrapPanel Grid.Row="1" Margin="0,6,0,0">
                <Button Content="Copy selected" Margin="0,0,4,4" Command="{Binding CopySelected}" />
                <Button Content="Copy all" Margin="0,0,4,4" Command="{Binding CopyAll}" />
                <Button Content="Clear" Margin="0,0,0,4" Command="{Binding ClearHistory}" />
            </WrapPanel>
        </Grid>
    </Grid>
</UserControl>
