<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        xmlns:shell="clr-namespace:App.Desktop.Shell"
        xmlns:modules="clr-namespace:App.Desktop.Modules"
        x:Class="App.Desktop.Shell.MainWindow"
        x:DataType="shell:ShellViewModel"
        Title="GM Tool"
        Icon="/Assets/Logo.ico"
        Width="1725" Height="860"
        MinWidth="1280" MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource Foreground}">
    <Grid ColumnDefinitions="*,310">
        <TabControl Grid.Column="0"
                    ItemsSource="{Binding Tabs}"
                    SelectedItem="{Binding SelectedTab}">
            <TabControl.ItemTemplate>
                <DataTemplate x:DataType="modules:ITabModule">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <i:Icon Value="{Binding IconKey}" />
                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center" />
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>
        </TabControl>
        <Border Grid.Column="1" Background="{DynamicResource SidebarBackground}" />
    </Grid>
</Window>
