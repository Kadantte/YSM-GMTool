<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:App.Desktop.Shell"
        xmlns:modules="clr-namespace:App.Desktop.Modules"
        x:Class="App.Desktop.Shell.MainWindow"
        x:DataType="shell:ShellViewModel"
        Title="GM Tool"
        Icon="/Assets/Logo.ico"
        Width="1725" Height="860"
        MinWidth="1280" MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource Foreground}">
    <DockPanel>
        <shell:TopBarView DockPanel.Dock="Top" DataContext="{Binding TopBar}" />
        <TabControl ItemsSource="{Binding Tabs}"
                    SelectedItem="{Binding SelectedTab}">
            <TabControl.ItemTemplate>
                <DataTemplate x:DataType="modules:ITabModule">
                    <TextBlock Text="{Binding Title}" />
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate x:DataType="modules:ITabModule">
                    <ContentControl Content="{Binding}" />
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </DockPanel>
</Window>
