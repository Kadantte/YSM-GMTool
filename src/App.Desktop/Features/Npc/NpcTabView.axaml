<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:App.Desktop.Controls"
             xmlns:npc="clr-namespace:App.Desktop.Features.Npc"
             x:Class="App.Desktop.Features.Npc.NpcTabView"
             x:Name="Root"
             x:DataType="npc:NpcTabViewModel"
             Background="{DynamicResource WindowBackground}">
    <controls:EntityBrowserView DataContext="{Binding Browser}">
        <controls:EntityBrowserView.Actions>
            <ScrollViewer DataContext="{Binding #Root.DataContext}">
                <StackPanel Spacing="8" Margin="0,8,0,0">

                    <!-- NPC -->
                    <TextBlock Classes="sectionHeader" Text="NPC" />
                    <Border Classes="sectionDivider" />

                    <WrapPanel>
                        <StackPanel Classes="field">
                            <TextBlock Classes="fieldLabel" Text="NPC ID" />
                            <NumericUpDown Minimum="0" Maximum="2000000000"
                                           Increment="1" FormatString="0" Value="{Binding NpcId}" />
                        </StackPanel>
                        <StackPanel Classes="field">
                            <TextBlock Classes="fieldLabel" Text="X" />
                            <NumericUpDown Minimum="-1000000" Maximum="1000000"
                                           Increment="1" FormatString="0" Value="{Binding NpcX}" />
                        </StackPanel>
                        <StackPanel Classes="field">
                            <TextBlock Classes="fieldLabel" Text="Y" />
                            <NumericUpDown Minimum="-1000000" Maximum="1000000"
                                           Increment="1" FormatString="0" Value="{Binding NpcY}" />
                        </StackPanel>
                        <StackPanel Classes="field">
                            <TextBlock Classes="fieldLabel" Text="Layer" />
                            <NumericUpDown Minimum="-1000" Maximum="1000"
                                           Increment="1" FormatString="0" Value="{Binding Layer}" />
                        </StackPanel>
                    </WrapPanel>

                    <CheckBox Content="Hide NPC" IsChecked="{Binding HideNpc}" />

                    <WrapPanel>
                        <Button Classes="primary" Content="Add NPC to world" Margin="0,0,6,6" Command="{Binding AddNpcToWorld}" />
                        <Button Content="Show / Hide NPC" Margin="0,0,6,6" Command="{Binding ShowHideNpc}" />
                        <Button Content="Warp to NPC" Margin="0,0,6,6" Command="{Binding WarpToNpc}" />
                    </WrapPanel>

                </StackPanel>
            </ScrollViewer>
        </controls:EntityBrowserView.Actions>
    </controls:EntityBrowserView>
</UserControl>
