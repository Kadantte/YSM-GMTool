<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="App.Desktop.Features.About.AboutWindow"
        Title="About"
        Width="360"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/Logo.ico"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource Foreground}">
    <StackPanel Margin="24" Spacing="12" HorizontalAlignment="Center">
        <Image Source="/Assets/Heaven_logo1.png"
               Width="160"
               Stretch="Uniform"
               HorizontalAlignment="Center" />
        <TextBlock Text="GM Tool"
                   FontSize="20"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center" />
        <TextBlock x:Name="VersionText"
                   Foreground="{DynamicResource MutedForeground}"
                   HorizontalAlignment="Center" />
        <Button Content="OK"
                MinWidth="84"
                IsDefault="True"
                IsCancel="True"
                HorizontalAlignment="Center"
                Click="OnOk" />
    </StackPanel>
</Window>
